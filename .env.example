# Aether CBT Environment
PORT=3000
DATABASE_URL=data/cbt_aether.db
ENV=development

# Change this in production!
JWT_SECRET=aether-cbt-secret-key-change-in-production

# CORS allow-list (WAJIB di production, pisahkan dengan koma).
# Contoh: https://app.sekolah.id,https://admin.sekolah.id
CORS_ALLOWED_ORIGINS=

# --- Database connection pool (SQLite WAL, skala ~500 siswa konkuren) ---
# WAL mengizinkan banyak pembaca paralel + satu penulis; penulisan hasil sudah
# diserialkan oleh worker queue, jadi pool moderat aman untuk pembacaan paralel.
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MIN=30

# --- Unggah paket soal iSpring ---
# Batas ukuran ZIP (byte). Default 100 MB.
SOAL_UPLOAD_MAX_BYTES=104857600
# Batas jumlah berkas per paket (anti zip-bomb).
SOAL_PACKAGE_MAX_FILES=5000

# --- Anti-cheat ---
# Ambang jumlah pelanggaran (mis. pindah tab) sebelum sesi dikunci server-side.
ANTICHEAT_LOCK_THRESHOLD=3

# --- Penyajian konten ---
# Flag Secure untuk cookie sesi konten (aether_exam).
# "auto" = aktif otomatis di HTTPS/production; set "true"/"false" untuk override.
CONTENT_COOKIE_SECURE=auto

# --- Submission queue (filesystem) ---
QUEUE_DIR=data/queue
QUEUE_MAX_RETRIES=5
QUEUE_STUCK_THRESHOLD_MIN=5
QUEUE_DONE_RETENTION_DAYS=7
QUEUE_BATCH_SIZE=5
QUEUE_BATCH_TIMEOUT_MS=100

# --- Webhook ---
# Batas rate webhook iSpring per menit.
WEBHOOK_RATE_LIMIT_PER_MIN=100
